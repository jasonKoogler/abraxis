# Environment
ENV=development  # Can be: development, staging, production
LOG_LEVEL=debug  # Can be: debug, info, warn, error, fatal

# Rate Limiting
USE_REDIS_RATE_LIMITER=true
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST=150
RATE_LIMIT_TTL=1h

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_database
POSTGRES_SSL_MODE=disable
POSTGRES_TIMEZONE=UTC
POSTGRES_TIMEOUT=30s

# Redpanda Configuration
REDPANDA_BROKERS=localhost:9092,localhost:9093
REDPANDA_GROUP=your_consumer_group
REDPANDA_TOPIC=your_topic

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USERNAME=default

# HTTP Server Configuration
HTTP_SERVER_PORT=8080
HTTP_SERVER_READ_TIMEOUT=10s
HTTP_SERVER_WRITE_TIMEOUT=10s
HTTP_SERVER_IDLE_TIMEOUT=10s
HTTP_SERVER_SHUTDOWN_TIMEOUT=10s
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT Authentication
USE_CUSTOM_JWT=true
JWT_SECRET=your_very_secure_jwt_secret_key
JWT_ISSUER=your_application_name
JWT_EXPIRATION=24h

# Social Authentication - Facebook
FACEBOOK_KEY=your_facebook_app_id
FACEBOOK_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:8080/auth/facebook/callback
FACEBOOK_SCOPES=email

# Social Authentication - Google
GOOGLE_KEY=your_google_client_id
GOOGLE_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/userinfo.profile

# # Social Authentication - GitHub
# GITHUB_KEY=your_github_client_id
# GITHUB_SECRET=your_github_client_secret
# GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback
# GITHUB_SCOPES=user:email

# Social Authentication - Twitter
TWITTER_KEY=your_twitter_api_key
TWITTER_SECRET=your_twitter_api_secret
TWITTER_CALLBACK_URL=http://localhost:8080/auth/twitter/callback
TWITTER_SCOPES=tweet.read,users.read

# Stripe Configuration
STRIPE_API_KEY=your_stripe_secret_key
STRIPE_ENDPOINT_SECRET=your_stripe_webhook_signing_secret
# APP_ENV=development
# LOG_LEVEL=debug
# JWT_SECRET=your_jwt_secret

